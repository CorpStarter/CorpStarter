{
  "info": {
    "name": "Corpstarter API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "AdminController",
      "item": [
        {
          "name": "Change Project Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/projects/:id/status?token=your_token_here",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "projects", ":id", "status"],
              "query": [
                { "key": "token", "value": "your_token_here" }
              ],
              "variable": [
                { "key": "id", "value": "1" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_id\": 1,\n  \"status_id\": 2\n}"
            }
          }
        },
        {
          "name": "Allocate Budget",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/projects/:id/budget?token=your_token_here",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "projects", ":id", "budget"],
              "query": [
                { "key": "token", "value": "your_token_here" }
              ],
              "variable": [
                { "key": "id", "value": "1" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_id\": 1,\n  \"allocated_budget\": 5000\n}"
            }
          }
        },
        {
          "name": "Create Project Status",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/project-status?token=your_token_here",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "project-status"],
              "query": [
                { "key": "token", "value": "your_token_here" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status_name\": \"New Status\",\n  \"validated\": true\n}"
            }
          }
        },
        {
          "name": "Create User Types",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/user-types?token=your_token_here",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "user-types"],
              "query": [
                { "key": "token", "value": "your_token_here" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User Type\",\n  \"can_accept_project\": true\n}"
            }
          }
        }
      ]
    },
    {

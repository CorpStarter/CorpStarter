    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"User_sophie\",\n  \"last_name\": \"Perret\",\n  \"first_name\": \"Sophie\",\n  \"password\": \"Password123!\",\n  \"email\": \"sophie.user@example.com\",\n  \"user_type\": \"User\"\n}"
            },
            "url": {
              "raw": "{{baseURL}}/auth/register",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Create a new user account. Returns token and user ID."
          },
          "response": []
        },
        {

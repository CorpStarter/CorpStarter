      ]
    },
    {
      "name": "ProjectController",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/projects?token=your_token_here",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects"],
              "query": [
                { "key": "token", "value": "your_token_here" }
              ]
            }
          }
        },

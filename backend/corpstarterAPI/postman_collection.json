                { "key": "id", "value": "1" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Project\",\n  \"requested_budget\": 15000\n}"
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/projects/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "projects", ":id"],
              "variable": [
                { "key": "id", "value": "1" }
              ]
            }
          }

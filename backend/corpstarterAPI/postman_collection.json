            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Project\",\n  \"user_id\": 1,\n  \"requested_budget\": 10000\n}"
            }
          }
        },
        {
          "name": "Edit Project",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
